import java.util.*;

// Notification interface
interface NotificationChannel {
    void send(String message);
}

// Email Notification
class EmailNotification implements NotificationChannel {
    public void send(String message) {
        System.out.println("Sending Email: " + message);
    }
}

// SMS Notification
class SMSNotification implements NotificationChannel {
    public void send(String message) {
        System.out.println("Sending SMS: " + message);
    }
}

// Push Notification
class PushNotification implements NotificationChannel {
    public void send(String message) {
        System.out.println("Sending Push Notification: " + message);
    }
}

// Singleton Notification Manager
class NotificationManager {
    private static NotificationManager instance;

    private Map<String, NotificationChannel> channels;

    // Private constructor
    private NotificationManager() {
        channels = new HashMap<>();
    }

    // Singleton instance method
    public static synchronized NotificationManager getInstance() {
        if (instance == null) {
            instance = new NotificationManager();
        }
        return instance;
    }

    // Register new channel (Pluggable)
    public void registerChannel(String type, NotificationChannel channel) {
        channels.put(type.toLowerCase(), channel);
    }

    // Send notification
    public void notify(String type, String message) {
        NotificationChannel channel = channels.get(type.toLowerCase());

        if (channel != null) {
            channel.send(message);
        } else {
            System.out.println("No notification channel found for: " + type);
        }
    }
}

// Main Class
public class Main {
    public static void main(String[] args) {

        NotificationManager manager = NotificationManager.getInstance();

        // Plugging channels dynamically
        manager.registerChannel("email", new EmailNotification());
        manager.registerChannel("sms", new SMSNotification());
        manager.registerChannel("push", new PushNotification());

        // Sending notifications
        manager.notify("email", "Welcome User!");
        manager.notify("sms", "Your OTP is 1234");
        manager.notify("push", "New message received");
    }
}
